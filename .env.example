# ── Gravity Claw Environment Variables ──────────────────────────
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to interact with the bot.
# Find your ID: message @userinfobot on Telegram
ALLOWED_USER_IDS=

# ── LLM ─────────────────────────────────────────────────────────

# LLM API key (default: "ollama" for local Ollama)
# LLM_API_KEY=ollama

# LLM base URL (default: http://localhost:11434/v1)
# LLM_BASE_URL=http://localhost:11434/v1

# LLM model ID (default: qwen3:8b)
# LLM_MODEL=qwen3:8b

# Max agent loop iterations before aborting (default: 10)
# MAX_AGENT_ITERATIONS=10

# ── TTS (Optional) ──────────────────────────────────────────────

# Kokoro TTS server URL (voice disabled if not set)
# KOKORO_URL=http://127.0.0.1:8880

# Kokoro voice ID
# KOKORO_VOICE=af_heart

# ── Shell Commands ──────────────────────────────────────────────

# Comma-separated allowlist of shell commands (default: common safe commands)
# SHELL_ALLOWED_COMMANDS=ls,cat,echo,date,whoami,git,node,npm,python

# Comma-separated allowed working directories for shell commands
# SHELL_ALLOWED_DIRS=.,/tmp

# Shell command timeout in milliseconds (default: 30000)
# SHELL_TIMEOUT=30000

# ── File Operations ─────────────────────────────────────────────

# Comma-separated allowed directories for file read/write (default: ./workspace,.,/tmp)
# FILE_ALLOWED_PATHS=./workspace,.,/tmp

# Max file size in bytes for read/write (default: 1048576 = 1MB)
# FILE_MAX_SIZE_BYTES=1048576

# ── Webhooks ────────────────────────────────────────────────────

# Port for the webhook HTTP server (default: 3456)
# WEBHOOK_PORT=3456

# Optional shared secret for webhook authentication
# WEBHOOK_SECRET=

# ── Google Sheets ───────────────────────────────────────────────

# Google Sheets spreadsheet ID
# GOOGLE_SHEET_ID=

# Local path to the Google service-account JSON file
# GOOGLE_CREDENTIALS_PATH=./service-account.json

# Raw Google service-account JSON contents
# Prefer this for Railway/cloud deploys instead of a file path
# GOOGLE_CREDENTIALS_JSON=

# ── MCP Bridge ──────────────────────────────────────────────────

# Path to MCP servers config JSON file (default: ./mcp-servers.json)
# MCP_CONFIG_PATH=./mcp-servers.json

# ── Skills ──────────────────────────────────────────────────────

# Path to skills directory containing .md files (default: ./skills)
# SKILLS_DIR=./skills

# ── Memory ──────────────────────────────────────────────────────

# Path to SQLite memory database (default: ./data/cortex.db)
# MEMORY_DB_PATH=./data/cortex.db

# Path to markdown notes directory (default: ./data/notes)
# NOTES_DIR=./data/notes

# Max context tokens before auto-pruning (default: 6000)
# MAX_CONTEXT_TOKENS=6000

# Days before unused memories start decaying (default: 30)
# MEMORY_DECAY_DAYS=30

# ── Semantic Memory (Mem0 + Pinecone) ───────────────────────────

# Pinecone API key (get free at https://www.pinecone.io/)
# PINECONE_API_KEY=

# Pinecone index name (default: gravityclaw-memory)
# PINECONE_INDEX_NAME=gravityclaw-memory

# Pinecone host URL (from your Pinecone dashboard)
# PINECONE_HOST=

# Embedding model (default: text-embedding-3-small)
# EMBEDDING_MODEL=text-embedding-3-small

# Embedding dimensions — must match the model (default: 1536)
# EMBEDDING_DIMS=1536
